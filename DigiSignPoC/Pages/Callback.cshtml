@page
@model CallbackModel
@{
    ViewData["Title"] = "DigiSign Verification Complete";
}

<h1>DigiSign verification</h1>

@if (!Model.CompletionRecorded)
{
    <div class="alert alert-danger" role="alert">
        <h2 class="h5 alert-heading">The verification result could not be returned to the PoC</h2>
        <p class="mb-0">@Model.ErrorMessage</p>
    </div>
    <a class="btn btn-primary" asp-page="/Index">Return to verification settings</a>
}
else
{
    <div class="alert alert-success" role="status">
        <h2 class="h5 alert-heading">Verification response received</h2>
        <p class="mb-0">
            The complete DigiSign response has been saved for the main PoC page.
            This popup will close automatically.
        </p>
    </div>
    <p id="closeFallback" class="text-muted" hidden>
        If this window does not close automatically, you can close it safely and return to the main PoC page.
    </p>

    @section Scripts {
        <script>
            const completionMessage = {
                type: 'digisign-verification-complete',
                flowId: @Json.Serialize(Model.FlowId)
            };

            if (window.opener) {
                window.opener.postMessage(completionMessage, window.location.origin);
            }

            if ('BroadcastChannel' in window) {
                const completionChannel = new BroadcastChannel('digisign-verification');
                completionChannel.postMessage(completionMessage);
                completionChannel.close();
            }

            window.setTimeout(() => window.close(), 500);
            window.setTimeout(() => {
                document.getElementById('closeFallback').hidden = false;
            }, 1200);
        </script>
    }
}
