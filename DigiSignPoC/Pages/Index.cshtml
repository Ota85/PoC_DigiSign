@page
@model IndexModel
@{
    ViewData["Title"] = "DigiSign Identify PoC";
}

<h1>DigiSign Identify PoC</h1>
<p class="lead">Configure authentication, select a scenario, and complete the provider flow from this page.</p>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">
        <strong>@Model.ErrorMessage</strong>
        @if (Model.ProviderError is not null)
        {
            <div class="mt-2">DigiSign details:</div>
            <pre class="mb-0 text-wrap">@Model.ProviderError</pre>
        }
    </div>
}

@if (Model.SuccessMessage is not null)
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (Model.VerificationUrl is not null)
{
    <div class="alert alert-success">
        <strong>Identification created and started.</strong>
        Review the information below, then open DigiSign in a popup. This page will remain visible.
    </div>

    <dl class="row">
        <dt class="col-sm-3">Identification ID</dt>
        <dd class="col-sm-9"><code>@Model.IdentificationId</code></dd>
        <dt class="col-sm-3">Start URL valid to</dt>
        <dd class="col-sm-9">@Model.ValidTo</dd>
        <dt class="col-sm-3">Verification URL</dt>
        <dd class="col-sm-9 text-break"><a href="@Model.VerificationUrl" target="digisign-verification">@Model.VerificationUrl</a></dd>
    </dl>

    <button class="btn btn-primary" type="button" id="openDigiSign">Open DigiSign verification</button>
    <button class="btn btn-outline-secondary" type="button" id="backToSettings">Back to verification settings</button>
    <a class="btn btn-outline-secondary" asp-page="/Index">Reset verification settings</a>
    <div class="alert alert-warning mt-3" id="popupWarning" role="alert" hidden>
        The DigiSign popup was blocked. Allow popups for this site, then try again, or
        <a href="@Model.VerificationUrl" target="digisign-verification">open DigiSign manually</a>.
    </div>

    @section Scripts {
        <script>
            const completionUrl = @Json.Serialize(Url.Page("/Callback"));
            const verificationUrl = @Json.Serialize(Model.VerificationUrl);
            const popupWarning = document.getElementById('popupWarning');

            function showVerificationResult() {
                window.location.href = completionUrl;
            }

            window.addEventListener('message', event => {
                if (event.origin === window.location.origin &&
                    event.data?.type === 'digisign-verification-complete') {
                    showVerificationResult();
                }
            });

            if ('BroadcastChannel' in window) {
                const completionChannel = new BroadcastChannel('digisign-verification');
                completionChannel.addEventListener('message', event => {
                    if (event.data?.type === 'digisign-verification-complete') {
                        showVerificationResult();
                    }
                });
            }

            document.getElementById('openDigiSign').addEventListener('click', () => {
                const popup = window.open(
                    verificationUrl,
                    'digisign-verification',
                    'popup=yes,width=1100,height=800,resizable=yes,scrollbars=yes');

                popupWarning.hidden = popup !== null;
                popup?.focus();
            });

            document.getElementById('backToSettings').addEventListener('click', () => {
                if (window.history.length > 1) {
                    window.history.back();
                } else {
                    window.location.href = @Json.Serialize(Url.Page("/Index"));
                }
            });

        </script>
    }
}
else
{
    <form method="post" id="verificationForm">
        <div class="card mb-4">
            <div class="card-header"><strong>1. DigiSign environment</strong></div>
            <div class="card-body">
                <label asp-for="Input.BaseUrl" class="form-label">DigiSign API base URL</label>
                <input asp-for="Input.BaseUrl" class="form-control" placeholder="https://api.staging.digisign.org" />
                <div class="form-text">Use staging credentials with the staging URL and production credentials with the production URL.</div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>2. Authentication</strong></div>
            <div class="card-body">
                <p>Use an existing bearer token, or obtain one from DigiSign API keys.</p>

                <label asp-for="Input.BearerToken" class="form-label">Bearer token (optional when API keys are entered)</label>
                <div class="input-group mb-2">
                    <input name="Input.BearerToken" type="password" class="form-control" id="bearerToken"
                           value="@Model.Input.BearerToken" autocomplete="off" />
                    <button class="btn btn-outline-secondary" type="button" id="toggleToken">Show</button>
                    <button class="btn btn-outline-secondary" type="button" id="copyToken">Copy</button>
                </div>
                @if (Model.TokenExpiresAt is not null)
                {
                    <div class="form-text mb-3">Token expires at @Model.TokenExpiresAt.</div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.AccessKey" class="form-label">accessKey</label>
                        <input asp-for="Input.AccessKey" class="form-control" autocomplete="off" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.SecretKey" class="form-label">secretKey</label>
                        <input asp-for="Input.SecretKey" type="password" class="form-control" autocomplete="new-password" />
                    </div>
                </div>

                <button type="submit" asp-page-handler="GetToken" class="btn btn-outline-primary mt-3">Get bearer token</button>
                <div class="form-text">The PoC does not save the API secret. Bearer tokens are temporary credentials.</div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>3. Verification scenario</strong></div>
            <div class="card-body">
                <label asp-for="Input.ScenarioId" class="form-label">Identify scenario ID</label>
                @if (Model.Scenarios.Count > 0)
                {
                    <select asp-for="Input.ScenarioId" class="form-select" id="scenarioId">
                        <option value="">Select a loaded scenario</option>
                        @foreach (var scenario in Model.Scenarios)
                        {
                            <option value="@scenario.Id" data-name="@scenario.Name" data-mode="@scenario.ApprovalMode">
                                @scenario.Name (@scenario.ApprovalMode)
                            </option>
                        }
                    </select>
                }
                else
                {
                    <input asp-for="Input.ScenarioId" class="form-control" id="scenarioId" placeholder="Scenario UUID" />
                }
                <button type="submit" asp-page-handler="LoadScenarios" class="btn btn-outline-primary mt-3">Load available scenarios</button>

                <div id="selectedScenario" class="alert alert-secondary mt-3 mb-0" role="status">
                    No verification scenario is selected.
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>4. Identification settings</strong></div>
            <div class="card-body">
                <div>
                    <label asp-for="Input.Name" class="form-label">Display name</label>
                    <input asp-for="Input.Name" class="form-control" />
                    <div class="form-text">A human-readable label for finding this verification in DigiSign administration.</div>
                </div>

                <details class="mt-3" id="additionalOptions">
                    <summary class="btn btn-outline-secondary">Advanced settings</summary>
                    <div class="border rounded p-3 mt-3">
                        <div class="mb-3">
                            <label asp-for="Input.RedirectUrl" class="form-label">Absolute redirect URL</label>
                            <input asp-for="Input.RedirectUrl" class="form-control" />
                            <div class="form-text">
                                The public HTTPS address returns DigiSign to this locally running PoC through the reverse proxy.
                            </div>
                            <div class="btn-group btn-group-sm mt-2" role="group" aria-label="Callback URL presets">
                                <button type="button" class="btn btn-outline-secondary callback-preset"
                                        data-url="https://sign.revolving.dev.linksoft.cz/Callback">Use public callback</button>
                                <button type="button" class="btn btn-outline-secondary callback-preset"
                                        data-url="http://localhost:5000/Callback">Use HTTP localhost</button>
                            </div>
                        </div>

                        <div>
                            <label asp-for="Input.LinkExpiration" class="form-label">Start-link validity in minutes</label>
                            <input asp-for="Input.LinkExpiration" type="number" min="0" max="10080" class="form-control" />
                            <div class="form-text">Keep 0 to use the DigiSign default, expected to be 5 minutes.</div>
                        </div>
                    </div>
                </details>
            </div>
        </div>

        <div id="readiness" class="alert alert-warning" role="status">
            Complete the required settings before starting verification.
        </div>

        <button type="submit" asp-page-handler="Start" class="btn btn-primary btn-lg"
                id="startVerification" disabled>Create and start verification</button>
    </form>

    @section Scripts {
        <script>
            const form = document.getElementById('verificationForm');
            const token = document.getElementById('bearerToken');
            const baseUrl = document.getElementById('Input_BaseUrl');
            const accessKey = document.getElementById('Input_AccessKey');
            const secretKey = document.getElementById('Input_SecretKey');
            const scenario = document.getElementById('scenarioId');
            const name = document.getElementById('Input_Name');
            const redirectUrl = document.getElementById('Input_RedirectUrl');
            const linkExpiration = document.getElementById('Input_LinkExpiration');
            const selectedScenario = document.getElementById('selectedScenario');
            const readiness = document.getElementById('readiness');
            const startButton = document.getElementById('startVerification');

            function isHttpUrl(value) {
                try {
                    const url = new URL(value);
                    return url.protocol === 'https:' || url.protocol === 'http:';
                } catch {
                    return false;
                }
            }

            function updateScenarioStatus() {
                const scenarioId = scenario.value.trim();
                if (!scenarioId) {
                    selectedScenario.className = 'alert alert-secondary mt-3 mb-0';
                    selectedScenario.textContent = 'No verification scenario is selected.';
                    return;
                }

                const selectedOption = scenario.tagName === 'SELECT'
                    ? scenario.options[scenario.selectedIndex]
                    : null;
                const description = selectedOption?.dataset.name
                    ? `${selectedOption.dataset.name} (${selectedOption.dataset.mode || 'mode not specified'})`
                    : 'Manually entered scenario';

                selectedScenario.className = 'alert alert-success mt-3 mb-0';
                selectedScenario.replaceChildren();
                const label = document.createElement('strong');
                label.textContent = 'Selected scenario:';
                const id = document.createElement('code');
                id.textContent = scenarioId;
                selectedScenario.append(label, ` ${description}`, document.createElement('br'), id);
            }

            function updateReadiness() {
                updateScenarioStatus();

                const checks = [
                    [isHttpUrl(baseUrl.value), 'DigiSign environment'],
                    [token.value.trim() || (accessKey.value.trim() && secretKey.value.trim()), 'authentication'],
                    [scenario.value.trim(), 'verification scenario'],
                    [name.value.trim(), 'display name'],
                    [isHttpUrl(redirectUrl.value), 'callback URL'],
                    [Number.isInteger(Number(linkExpiration.value)) &&
                        Number(linkExpiration.value) >= 0 &&
                        Number(linkExpiration.value) <= 10080, 'link validity']
                ];
                const missing = checks.filter(check => !check[0]).map(check => check[1]);
                const ready = missing.length === 0;

                startButton.disabled = !ready;
                readiness.className = ready ? 'alert alert-success' : 'alert alert-warning';
                readiness.innerHTML = ready
                    ? '<strong>Ready.</strong> Required settings are complete. You can create and start verification.'
                    : `<strong>Not ready.</strong> Check: ${missing.join(', ')}.`;
            }

            document.getElementById('toggleToken').addEventListener('click', event => {
                token.type = token.type === 'password' ? 'text' : 'password';
                event.target.textContent = token.type === 'password' ? 'Show' : 'Hide';
            });
            document.getElementById('copyToken').addEventListener('click', async () => {
                await navigator.clipboard.writeText(token.value);
            });
            document.querySelectorAll('.callback-preset').forEach(button => {
                button.addEventListener('click', () => {
                    redirectUrl.value = button.dataset.url;
                    updateReadiness();
                });
            });
            [baseUrl, token, accessKey, secretKey, scenario, name, redirectUrl, linkExpiration]
                .forEach(input => {
                    input.addEventListener('input', updateReadiness);
                    input.addEventListener('change', updateReadiness);
                });

            form.addEventListener('submit', event => {
                if (event.submitter?.id === 'startVerification' && startButton.disabled) {
                    event.preventDefault();
                    updateReadiness();
                }
            });

            updateReadiness();
        </script>
    }
}
