@page
@model IndexModel
@{
    ViewData["Title"] = "DigiSign Identify PoC";
}

<h1>DigiSign Identify PoC</h1>
<p class="lead">Configure authentication, select a scenario, and complete the provider flow from this page.</p>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.SuccessMessage is not null)
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (Model.VerificationUrl is not null)
{
    <div class="alert alert-success">
        <strong>Identification created and started.</strong>
        DigiSign should open in a new tab automatically.
        If it does not, <a href="@Model.VerificationUrl" target="_blank" rel="noopener noreferrer">open DigiSign manually</a>.
    </div>

    <dl class="row">
        <dt class="col-sm-3">Identification ID</dt>
        <dd class="col-sm-9"><code>@Model.IdentificationId</code></dd>
        <dt class="col-sm-3">Start URL valid to</dt>
        <dd class="col-sm-9">@Model.ValidTo</dd>
        <dt class="col-sm-3">Verification URL</dt>
        <dd class="col-sm-9 text-break"><a href="@Model.VerificationUrl" target="_blank" rel="noopener noreferrer">@Model.VerificationUrl</a></dd>
    </dl>

    <a class="btn btn-secondary" asp-page="/Index">Start another verification</a>

    @section Scripts {
        <script>window.open(@Json.Serialize(Model.VerificationUrl), '_blank', 'noopener,noreferrer');</script>
    }
}
else
{
    <form method="post">
        <div class="card mb-4">
            <div class="card-header"><strong>1. DigiSign environment</strong></div>
            <div class="card-body">
                <label asp-for="Input.BaseUrl" class="form-label">DigiSign API base URL</label>
                <input asp-for="Input.BaseUrl" class="form-control" placeholder="https://api.staging.digisign.org" />
                <div class="form-text">Use staging credentials with the staging URL and production credentials with the production URL.</div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>2. Authentication</strong></div>
            <div class="card-body">
                <p>Use an existing bearer token, or obtain one from DigiSign API keys.</p>

                <label asp-for="Input.BearerToken" class="form-label">Bearer token (optional when API keys are entered)</label>
                <div class="input-group mb-2">
                    <input name="Input.BearerToken" type="password" class="form-control" id="bearerToken"
                           value="@Model.Input.BearerToken" autocomplete="off" />
                    <button class="btn btn-outline-secondary" type="button" id="toggleToken">Show</button>
                    <button class="btn btn-outline-secondary" type="button" id="copyToken">Copy</button>
                </div>
                @if (Model.TokenExpiresAt is not null)
                {
                    <div class="form-text mb-3">Token expires at @Model.TokenExpiresAt.</div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.AccessKey" class="form-label">accessKey</label>
                        <input asp-for="Input.AccessKey" class="form-control" autocomplete="off" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.SecretKey" class="form-label">secretKey</label>
                        <input asp-for="Input.SecretKey" type="password" class="form-control" autocomplete="new-password" />
                    </div>
                </div>

                <button type="submit" asp-page-handler="GetToken" class="btn btn-outline-primary mt-3">Get bearer token</button>
                <div class="form-text">The PoC does not save the API secret. Bearer tokens are temporary credentials.</div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>3. Verification scenario</strong></div>
            <div class="card-body">
                <label asp-for="Input.ScenarioId" class="form-label">Identify scenario ID</label>
                <input asp-for="Input.ScenarioId" class="form-control" list="scenarioOptions" placeholder="Scenario UUID" />
                <datalist id="scenarioOptions">
                    @foreach (var scenario in Model.Scenarios)
                    {
                        <option value="@scenario.Id">@scenario.Name (@scenario.ApprovalMode)</option>
                    }
                </datalist>
                <button type="submit" asp-page-handler="LoadScenarios" class="btn btn-outline-primary mt-3">Load available scenarios</button>

                @if (Model.Scenarios.Count > 0)
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Approval mode</th><th>ID</th></tr></thead>
                            <tbody>
                            @foreach (var scenario in Model.Scenarios)
                            {
                                <tr><td>@scenario.Name</td><td>@scenario.ApprovalMode</td><td><code>@scenario.Id</code></td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header"><strong>4. Identification settings</strong></div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.Name" class="form-label">Display name</label>
                        <input asp-for="Input.Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.LinkExpiration" class="form-label">Start-link validity in minutes</label>
                        <input asp-for="Input.LinkExpiration" type="number" min="0" max="10080" class="form-control" />
                        <div class="form-text">0 uses the DigiSign default (5 minutes).</div>
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.RedirectUrl" class="form-label">Absolute redirect URL</label>
                        <input asp-for="Input.RedirectUrl" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" asp-page-handler="Start" class="btn btn-primary btn-lg">Create and start verification</button>
    </form>

    @section Scripts {
        <script>
            const token = document.getElementById('bearerToken');
            document.getElementById('toggleToken').addEventListener('click', event => {
                token.type = token.type === 'password' ? 'text' : 'password';
                event.target.textContent = token.type === 'password' ? 'Show' : 'Hide';
            });
            document.getElementById('copyToken').addEventListener('click', async () => {
                await navigator.clipboard.writeText(token.value);
            });
        </script>
    }
}
